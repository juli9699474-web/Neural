{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@neural/shared/*": ["packages/shared/src/*"],
      "@neural/sdk/*": ["packages/sdk/src/*"]
    }
  }
}
